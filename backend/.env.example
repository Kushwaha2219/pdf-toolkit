# Copy this file to ".env" and fill in your values.
# The backend reads these on startup (via python-dotenv).

# --- Database backend ---
# "sqlite" (default): a local users.db file. No server, no admin rights needed.
# "mysql":            use the MYSQL_* settings below (for production/deploy).
DB_ENGINE=sqlite

# --- MySQL / MariaDB connection (only used when DB_ENGINE=mysql) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=pdfvish

# --- Auth ---
# Secret used to sign JWT tokens. Use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# --- Email (verification codes via Resend) ---
# Get an API key at https://resend.com. Without it, signup still works but the
# 6-digit code is shown on-screen (dev mode) instead of being emailed.
RESEND_API_KEY=
# Sender address. Resend's shared test sender works without a domain, but can
# only deliver to your own Resend account email. Verify a domain to email anyone.
MAIL_FROM=PDFVish <onboarding@resend.dev>

# Set to "false" in production so verification codes are never returned in API
# responses (they must come from email instead).
AUTH_DEV_MODE=true
